# ==========================================
# AuDHD Pipeline Environment Configuration
# ==========================================

# 1. API Keys (Required for different synthesis layers)
# You don't need all them if you only use one model, but the default architecture requires these three:
GROQ_API_KEY="your_groq_api_key_here"
GEMINI_API_KEY="your_gemini_api_key_here"
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# 2. Filesystem Configuration
# Path to your Obsidian vault where the resulting notes will be saved.
OBSIDIAN_VAULT_PATH="/Users/yourname/Documents/Obsidian"

# Optional: Where the raw audio and clipboard dumps are saved before processing.
# If not set, it defaults to ~/.audhd/inbox
# AUDHD_INBOX_PATH="/Users/yourname/.audhd/inbox"
